<!DOCTYPE html>
<html lang="id">
  <head>
    <%- include('../../partials/head') %>
  </head>
  <body class="home-page storefront-page">
    <header class="storefront-header">
      <div class="storefront-header__main">
        <a href="/" class="brand-logo" aria-label="Prosperoudia">
          <img src="/images/logo-panjang.jpeg" alt="Prosperoudia" />
        </a>

        <div class="storefront-actions">
          <div class="cart-preview">
            <a href="/cart" class="cart-link cart-link-icon-only" aria-label="Lihat keranjang belanja">
              <span class="cart-link__icon">🛒</span>
              <% if (cart.totalQuantity > 0) { %>
                <span class="cart-link__count"><%= cart.totalQuantity %></span>
              <% } %>
            </a>
            <div class="cart-preview__panel">
              <% if (cart.isEmpty) { %>
                <div class="cart-preview__empty">
                  <strong>Keranjang belanjamu kosong</strong>
                  <p>Yuk, isi dengan obat dan kebutuhan kesehatan harian.</p>
                  <a href="/" class="button-outline button-outline-block">Mulai Belanja</a>
                </div>
              <% } else { %>
                <div class="cart-preview__items">
                  <% cart.previewItems.forEach((item) => { %>
                    <article class="cart-preview__item">
                      <div>
                        <strong><%= item.name %></strong>
                        <span><%= item.quantity %> x <%= item.unit_price_label %></span>
                      </div>
                      <span><%= item.line_total_label %></span>
                    </article>
                  <% }) %>
                </div>
                <div class="cart-preview__footer">
                  <strong>Total <%= cart.totalAmountLabel %></strong>
                  <a href="/cart">Lihat semua</a>
                </div>
              <% } %>
            </div>
          </div>
          <% if (!currentUser) { %>
            <a href="/register?mode=login" class="storefront-login storefront-login-soft">Masuk</a>
            <a href="/register" class="button-ghost">Daftar</a>
          <% } else { %>
            <details class="profile-menu">
              <summary class="profile-menu__trigger">
                <span class="profile-avatar"><%= currentUser.full_name.charAt(0).toUpperCase() %></span>
                <span class="profile-name"><%= currentUser.full_name %></span>
              </summary>
              <div class="profile-menu__panel">
                <a href="/dashboard">Dashboard</a>
                <form action="/logout" method="post">
                  <%- include('../../partials/csrf-field') %>
                  <button type="submit">Logout</button>
                </form>
              </div>
            </details>
          <% } %>
        </div>
      </div>
    </header>

    <main class="storefront-shell">
      <% if (flashMessage) { %>
        <div class="alert <%= flashType === 'danger' ? 'alert-danger' : 'alert-info' %>"><%= flashMessage %></div>
      <% } %>

      <nav class="storefront-breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span>›</span>
        <span>Keranjang</span>
      </nav>

      <% if (!cart.items.length) { %>
        <section class="cart-empty-state">
          <div class="cart-empty-state__icon">🧺</div>
          <h1>Keranjang belanjamu kosong</h1>
          <p>Isi dulu dengan obat, vitamin, atau alat kesehatan yang kamu butuhkan.</p>
          <div class="cart-empty-state__actions">
            <a href="/" class="button-solid">Mulai Belanja</a>
            <a href="/register?mode=login" class="button-outline">Masuk</a>
          </div>
        </section>
      <% } else { %>
        <section class="cart-layout cart-layout-storefront">
          <article class="cart-panel">
            <div class="cart-panel__header">
              <div>
                <p class="eyebrow">Keranjang</p>
                <h1>Keranjang belanja</h1>
              </div>
              <a href="/" class="button-outline">Tambah produk</a>
            </div>

            <div class="cart-list cart-list-storefront">
              <% cart.items.forEach((item) => { %>
                <article class="cart-item cart-item-storefront">
                  <div class="cart-item-storefront__main">
                    <div class="cart-item-storefront__thumb">
                      <span><%= item.sku %></span>
                    </div>
                    <div class="cart-item-storefront__content">
                      <strong><%= item.name %></strong>
                      <span><%= item.category_name %></span>
                      <span><%= item.requires_prescription ? 'Memerlukan resep dokter' : 'Tanpa resep' %></span>
                    </div>
                  </div>

                  <div class="cart-item-storefront__side">
                    <form action="/cart/items/<%= item.medicine_id %>/update" method="post" class="cart-item__qty-form cart-item__qty-form-inline">
                      <%- include('../../partials/csrf-field') %>
                      <input type="number" min="1" name="quantity" value="<%= item.quantity %>" />
                      <button type="submit" class="button-outline">Update</button>
                    </form>
                    <div class="cart-item__price">
                      <strong><%= item.line_total_label %></strong>
                      <span><%= item.unit_price_label %> x <%= item.quantity %></span>
                    </div>
                    <form action="/cart/items/<%= item.medicine_id %>/remove" method="post">
                      <%- include('../../partials/csrf-field') %>
                      <button type="submit" class="button-ghost">Hapus</button>
                    </form>
                  </div>
                </article>
              <% }) %>
            </div>
          </article>

          <aside class="cart-summary-card">
            <h2>Ringkasan belanja</h2>
            <dl class="detail-list">
              <div>
                <dt>Total item</dt>
                <dd><%= cart.totalQuantity %></dd>
              </div>
              <div>
                <dt>Total belanja</dt>
                <dd><strong><%= cart.totalAmountLabel %></strong></dd>
              </div>
            </dl>

            <div class="cart-summary__actions">
              <% if (currentUser) { %>
                <a href="/checkout" class="button-solid">Lanjut ke Checkout</a>
              <% } else { %>
                <a href="/register?mode=login" class="button-solid">Masuk untuk Checkout</a>
                <a href="/register" class="button-outline">Daftar akun</a>
              <% } %>
            </div>
          </aside>
        </section>
      <% } %>
    </main>
  </body>
</html>
