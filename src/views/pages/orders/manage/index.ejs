<%- include('../../../partials/backoffice-shell-start', { activePage: 'orders' }) %>

      <% if (flashMessage) { %>
        <div class="alert <%= flashType === 'danger' ? 'alert-danger' : 'alert-info' %>"><%= flashMessage %></div>
      <% } %>

      <section class="panel-grid">
        <article class="panel-card">
          <h2>Daftar Order</h2>
          <% if (!orders.length) { %>
            <p class="subtitle">Belum ada order yang tercatat.</p>
          <% } else { %>
            <div class="table-shell">
              <table class="data-table">
                <thead>
                  <tr>
                    <th>No. Order</th>
                    <th>Pelanggan</th>
                    <th>Total</th>
                    <th>Status</th>
                    <th>Pembayaran</th>
                    <th>Bukti Bayar</th>
                    <th>Aksi</th>
                  </tr>
                </thead>
                <tbody>
                  <% orders.forEach((order) => { %>
                    <tr>
                      <td><strong><%= order.order_number %></strong></td>
                      <td>
                        <div><%= order.customer_name %></div>
                        <small class="subtitle"><%= order.customer_phone %></small>
                      </td>
                      <td><%= order.total_amount_label %></td>
                      <td><span class="status-pill <%= order.status === 'confirmed' || order.status === 'completed' ? 'status-active' : order.status === 'cancelled' ? 'status-muted' : 'status-warning' %>"><%= order.statusLabel %></span></td>
                      <td><%= order.paymentStatusLabel %></td>
                      <td>
                        <span class="status-pill <%= order.hasPaymentProof ? 'status-active' : 'status-warning' %>"><%= order.paymentProofStatusLabel %></span>
                      </td>
                      <td><a href="/orders/manage/<%= order.id %>" class="button-outline">Buka</a></td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          <% } %>
        </article>
      </section>
<%- include('../../../partials/backoffice-shell-end') %>
