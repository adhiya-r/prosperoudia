<!DOCTYPE html>
<html lang="id">
  <head>
    <%- include('../../partials/head') %>
  </head>
  <body class="storefront-page profile-page">
    <%- include('../../partials/storefront-header') %>

    <main class="storefront-shell">
      <nav class="storefront-breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span>›</span>
        <span>Edit Profil</span>
      </nav>

      <div class="profile-edit-layout">
        <%- include('../../partials/profile-sidebar', { activePage: 'edit' }) %>

        <div class="profile-edit-content">
          <% if (flashMessage) { %>
            <div class="alert alert--<%= flashType === 'success' ? 'success' : 'error' %>">
              <i class="fa-solid fa-<%= flashType === 'success' ? 'circle-check' : 'triangle-exclamation' %>"></i>
              <%= flashMessage %>
            </div>
          <% } %>

          <!-- Edit Data Profil -->
          <section class="profile-card">
            <div class="profile-card__header">
              <h1><i class="fa-solid fa-user-pen"></i> Edit Profil</h1>
              <p>Perbarui informasi akun Anda</p>
            </div>
            <form action="<%= profileActions.account %>" method="post" class="profile-form" novalidate>
              <%- include('../../partials/csrf-field') %>

              <div class="form-row">
                <div class="form-group <%= formErrors.full_name ? 'form-group--error' : '' %>">
                  <label for="full_name">Nama Lengkap <span class="required">*</span></label>
                  <input
                    type="text"
                    id="full_name"
                    name="full_name"
                    value="<%= formValues.full_name %>"
                    placeholder="Nama lengkap Anda"
                    autocomplete="name"
                    required
                  />
                  <% if (formErrors.full_name) { %>
                    <span class="form-error"><i class="fa-solid fa-circle-xmark"></i> <%= formErrors.full_name %></span>
                  <% } %>
                </div>

                <div class="form-group <%= formErrors.username ? 'form-group--error' : '' %>">
                  <label for="username">Username <span class="required">*</span></label>
                  <input
                    type="text"
                    id="username"
                    name="username"
                    value="<%= formValues.username %>"
                    placeholder="Username unik Anda"
                    autocomplete="username"
                    required
                  />
                  <% if (formErrors.username) { %>
                    <span class="form-error"><i class="fa-solid fa-circle-xmark"></i> <%= formErrors.username %></span>
                  <% } %>
                </div>
              </div>

              <div class="form-row">
                <div class="form-group <%= formErrors.email ? 'form-group--error' : '' %>">
                  <label for="email">Email <span class="required">*</span></label>
                  <input
                    type="email"
                    id="email"
                    name="email"
                    value="<%= formValues.email %>"
                    placeholder="email@contoh.com"
                    autocomplete="email"
                    required
                  />
                  <% if (formErrors.email) { %>
                    <span class="form-error"><i class="fa-solid fa-circle-xmark"></i> <%= formErrors.email %></span>
                  <% } %>
                </div>

                <div class="form-group <%= formErrors.phone ? 'form-group--error' : '' %>">
                  <label for="phone">Nomor HP</label>
                  <input
                    type="tel"
                    id="phone"
                    name="phone"
                    value="<%= formValues.phone %>"
                    placeholder="08xxxxxxxxxx"
                    autocomplete="tel"
                  />
                  <% if (formErrors.phone) { %>
                    <span class="form-error"><i class="fa-solid fa-circle-xmark"></i> <%= formErrors.phone %></span>
                  <% } %>
                </div>
              </div>

              <div class="form-actions">
                <button type="submit" class="button-primary">
                  <i class="fa-solid fa-floppy-disk"></i> Simpan Perubahan
                </button>
              </div>
            </form>
          </section>

          <!-- Ganti Password -->
          <section class="profile-card profile-card--danger-zone">
            <div class="profile-card__header">
              <h2><i class="fa-solid fa-lock"></i> Ganti Password</h2>
              <p>Pastikan akun Anda menggunakan password yang kuat</p>
            </div>
            <form action="<%= profileActions.password %>" method="post" class="profile-form" novalidate>
              <%- include('../../partials/csrf-field') %>

              <div class="form-group <%= passwordErrors.current_password ? 'form-group--error' : '' %>">
                <label for="current_password">Password Saat Ini <span class="required">*</span></label>
                <input
                  type="password"
                  id="current_password"
                  name="current_password"
                  placeholder="Masukkan password saat ini"
                  autocomplete="current-password"
                  required
                />
                <% if (passwordErrors.current_password) { %>
                  <span class="form-error"><i class="fa-solid fa-circle-xmark"></i> <%= passwordErrors.current_password %></span>
                <% } %>
              </div>

              <div class="form-row">
                <div class="form-group <%= passwordErrors.new_password ? 'form-group--error' : '' %>">
                  <label for="new_password">Password Baru <span class="required">*</span></label>
                  <input
                    type="password"
                    id="new_password"
                    name="new_password"
                    placeholder="Password baru (min. 8 karakter)"
                    autocomplete="new-password"
                    required
                  />
                  <% if (passwordErrors.new_password) { %>
                    <span class="form-error"><i class="fa-solid fa-circle-xmark"></i> <%= passwordErrors.new_password %></span>
                  <% } %>
                </div>

                <div class="form-group <%= passwordErrors.confirm_password ? 'form-group--error' : '' %>">
                  <label for="confirm_password">Konfirmasi Password <span class="required">*</span></label>
                  <input
                    type="password"
                    id="confirm_password"
                    name="confirm_password"
                    placeholder="Ulangi password baru"
                    autocomplete="new-password"
                    required
                  />
                  <% if (passwordErrors.confirm_password) { %>
                    <span class="form-error"><i class="fa-solid fa-circle-xmark"></i> <%= passwordErrors.confirm_password %></span>
                  <% } %>
                </div>
              </div>

              <div class="form-actions">
                <button type="submit" class="button-outline button-outline--danger">
                  <i class="fa-solid fa-key"></i> Ganti Password
                </button>
              </div>
            </form>
          </section>

          <!-- Info Akun -->
          <section class="profile-card profile-card--muted">
            <div class="profile-card__header">
              <h2><i class="fa-solid fa-circle-info"></i> Informasi Akun</h2>
            </div>
            <dl class="profile-info-list">
              <div>
                <dt>Terdaftar sejak</dt>
                <dd>
                  <%
                    const joinDate = new Date(user.created_at);
                    const opts = { day: 'numeric', month: 'long', year: 'numeric' };
                  %>
                  <%= joinDate.toLocaleDateString('id-ID', opts) %>
                </dd>
              </div>
              <div>
                <dt>Status akun</dt>
                <dd>
                  <span class="badge badge--<%= user.is_active ? 'success' : 'danger' %>">
                    <i class="fa-solid fa-<%= user.is_active ? 'circle-check' : 'circle-xmark' %>"></i>
                    <%= user.is_active ? 'Aktif' : 'Tidak aktif' %>
                  </span>
                </dd>
              </div>
            </dl>
          </section>
        </div>
      </div>
    </main>

    <footer class="storefront-footer">
      <p>&copy; <%= currentYear %> <%= appName %>. Semua hak dilindungi.</p>
    </footer>
  </body>
</html>
