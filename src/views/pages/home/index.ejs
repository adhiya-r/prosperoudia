<!DOCTYPE html>
<html lang="id">
  <head>
    <%- include('../../partials/head') %>
  </head>
  <body class="home-page storefront-page">
    <%- include('../../partials/storefront-header') %>

    <main class="storefront-shell">
      <nav class="storefront-breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span>›</span>
        <span data-i18n="storefront.health_store">Toko Kesehatan</span>
      </nav>

      <section class="storefront-search-panel">
        <form action="/" method="get" class="storefront-search" role="search">
          <input
            type="search"
            name="q"
            value="<%= searchQuery %>"
            placeholder="Cari obat, vitamin, atau alat kesehatan"
            data-i18n-placeholder="storefront.search_placeholder"
            aria-label="Cari produk"
            autocomplete="off"
            data-search-input
          />
          <input type="hidden" name="category" value="<%= activeCategoryFilter %>" data-active-category />
          <button type="submit" class="storefront-search__button" data-i18n="storefront.search">Cari</button>
        </form>
        <div class="search-suggestions" data-search-suggestions hidden></div>
      </section>

      <section id="catalog" class="storefront-catalog">
        <aside class="catalog-sidebar">
          <div class="catalog-sidebar__card">
            <h2><%= catalogSidebar.title %></h2>
            <% catalogSidebar.sections.forEach((section) => { %>
              <details class="catalog-sidebar__section" open>
                <summary>
                  <a href="/?category=<%= encodeURIComponent(section.categoryCode) %>#catalog"><%= section.heading %></a>
                </summary>
                <ul>
                  <% section.items.forEach((item) => { %>
                    <li>
                      <% if (item.categoryCode) { %>
                        <a href="/?category=<%= encodeURIComponent(item.categoryCode) %>#catalog"><%= item.label %></a>
                      <% } else { %>
                        <a href="/?q=<%= encodeURIComponent(item.search) %>#catalog"><%= item.label %></a>
                      <% } %>
                    </li>
                  <% }) %>
                </ul>
              </details>
            <% }) %>
          </div>
        </aside>

        <div class="catalog-main">
          <div class="catalog-main__chips" aria-label="Sorotan kategori">
            <% categoryHighlights.forEach((category, index) => { %>
              <a
                href="/?category=<%= encodeURIComponent(category.code) %>#catalog"
                class="catalog-chip <%= activeCategoryFilter === category.code || (!activeCategoryFilter && index === 0) ? 'is-active' : '' %>"
              ><%= category.name %></a>
            <% }) %>
          </div>

          <div class="catalog-product-grid">
            <% featuredProducts.forEach((product) => { %>
              <article class="catalog-product-card">
                <div class="catalog-product-card__media">
                  <% if (product.image_path) { %>
                    <img src="<%= product.image_path %>" alt="<%= product.name %>" class="catalog-product-card__image" />
                  <% } else { %>
                    <div class="catalog-product-card__placeholder product-cover-<%= product.accent %>">
                      <span class="product-cover__sku"><%= product.sku %></span>
                    </div>
                  <% } %>
                </div>

                <div class="catalog-product-card__body">
                  <h3>
                    <a href="/medicines/<%= product.id %>" class="product-link"><%= product.name %></a>
                  </h3>
                  <p class="catalog-product-card__unit"><%= product.dosage_form || 'Per item' %></p>
                  <p class="catalog-product-card__price"><%= product.price_label %></p>
                  <p class="catalog-product-card__meta">
                    <span><%= product.category %></span>
                    <% if (product.current_stock > 0) { %>
                      <span>Stok <%= product.current_stock %></span>
                    <% } %>
                  </p>
                </div>

                <div class="catalog-product-card__actions">
                  <form action="/cart/items" method="post" class="inline-form">
                    <%- include('../../partials/csrf-field') %>
                    <input type="hidden" name="medicine_id" value="<%= product.id %>" />
                    <input type="hidden" name="quantity" value="1" />
                    <input type="hidden" name="redirect_to" value="/" />
                    <button type="submit" class="catalog-add-button">Tambah</button>
                  </form>
                </div>
              </article>
            <% }) %>
          </div>
        </div>
      </section>
    </main>

    <div class="modal-backdrop <%= isLoginOpen ? 'is-visible' : '' %>" data-login-modal>
      <section class="auth-modal" role="dialog" aria-modal="true" aria-labelledby="login-title">
        <button type="button" class="modal-close" data-close-login aria-label="Tutup modal">×</button>

        <div class="modal-copy">
          <img src="/images/logo-panjang.jpeg" alt="Prosperoudia" class="auth-modal__logo" />
          <p class="eyebrow">Masuk</p>
          <h2 id="login-title">Masuk ke akunmu</h2>
          <p class="subtitle">Gunakan email atau username yang sudah terdaftar.</p>
        </div>

        <% if (loginError) { %>
          <div class="alert alert-danger"><%= loginError %></div>
        <% } %>

        <form action="/login" method="post" class="auth-form auth-form-compact">
          <%- include('../../partials/csrf-field') %>
          <input type="hidden" name="redirect_to" value="/" />

          <label class="field">
            <span>Email atau Username</span>
            <input
              type="text"
              name="identifier"
              value="<%= loginFormValues.identifier %>"
              placeholder="Email atau username"
              autocomplete="username"
            />
          </label>

          <label class="field">
            <span>Password</span>
            <div class="password-field">
              <input
                type="password"
                name="password"
                placeholder="Password"
                autocomplete="current-password"
                data-password-input
              />
              <button type="button" class="password-toggle" data-password-toggle>Lihat</button>
            </div>
          </label>

          <button type="submit" class="button-solid button-solid-block">Masuk</button>
        </form>

        <div class="auth-divider"><span>atau</span></div>

        <div class="placeholder-stack">
          <a href="/auth/google" class="button-outline button-outline-block" style="display: flex; align-items: center; justify-content: center; gap: 8px; text-decoration: none;">
            <i class="fa-brands fa-google"></i>
            Masuk dengan Google
          </a>
        </div>

        <p class="auth-help">
          Belum punya akun?
          <a href="/register">Daftar sekarang</a>
        </p>
      </section>
    </div>

    <script src="/dashboard-assets/js/ui.js" defer></script>
    <script src="/js/home.js" defer></script>
  </body>
</html>
