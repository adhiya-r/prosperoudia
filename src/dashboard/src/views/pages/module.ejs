<%- include('../partials/head', { pageTitle }) %>

<div class="app-shell">
  <%- include('../partials/sidebar', { activePage: moduleSlug }) %>

  <div class="main-column">
    <%- include('../partials/topbar', { pageTitle }) %>

    <main class="page-content">
      <section class="module-pagebar">
        <div class="module-pagebar__copy">
          <p class="eyebrow"><%= moduleStatus %></p>
          <p class="module-pagebar__text"><%= moduleDescription %></p>
        </div>
        <div class="module-pagebar__actions">
          <% if (typeof extraActions !== 'undefined' && Array.isArray(extraActions)) { %>
            <% extraActions.forEach(function(action) { %>
              <% if (action.type === 'form') { %>
                <form action="<%= action.action %>" method="post" class="inline-form">
                  <% if (typeof csrfToken !== 'undefined' && csrfToken) { %>
                    <input type="hidden" name="csrfToken" value="<%= csrfToken %>">
                  <% } %>
                  <% (action.hiddenFields || []).forEach(function(field) { %>
                    <input type="hidden" name="<%= field.name %>" value="<%= field.value %>">
                  <% }) %>
                  <button class="btn <%= action.variant === 'primary' ? 'btn-primary' : 'btn-secondary' %>" type="submit"><%= action.label %></button>
                </form>
              <% } else { %>
                <a class="btn <%= action.variant === 'primary' ? 'btn-primary' : 'btn-secondary' %>" href="<%= action.href %>"><%= action.label %></a>
              <% } %>
            <% }) %>
          <% } %>
          <% if (typeof createPath !== 'undefined' && createPath) { %>
            <a class="btn btn-primary" href="<%= createPath %>"><%= typeof createLabel !== 'undefined' && createLabel ? createLabel : 'Tambah Baru' %></a>
          <% } %>
          <a class="btn btn-secondary" href="/dashboard" data-i18n="module.go_dashboard">Dashboard</a>
        </div>
      </section>

      <% if (flashMessage) { %>
        <section class="panel">
          <div class="alert alert--<%= flashType || 'info' %>">
            <strong><%= flashMessage %></strong>
          </div>
        </section>
      <% } %>

      <section class="metric-grid">
        <% metrics.forEach(function(metric) { %>
          <article class="metric-card">
            <p class="metric-card__label"><%= metric.label %></p>
            <p class="metric-card__value"><%= metric.value %></p>
          </article>
        <% }) %>
      </section>

      <section class="panel">
        <div class="panel__header">
          <div>
            <h2 class="panel__title" data-i18n="module.table_data"><%= tableHeading || 'Tabel Data' %></h2>
            <p class="panel__subtext" data-i18n="module.manage_hint">Gunakan tabel ini untuk cek, cari, ubah, dan kelola data.</p>
          </div>
          <span class="badge badge--warning" data-i18n="module.data_badge"><%= tableBadge || 'Data' %></span>
        </div>

        <% if (typeof listControls !== 'undefined' && listControls) { %>
          <form class="module-filters" action="<%= listControls.action %>" method="get">
            <div class="module-filters__grid">
              <div class="form-group">
                <label class="form-label" for="module-search" data-i18n="module.search">Search</label>
                <input
                  class="form-input"
                  id="module-search"
                  name="q"
                  type="search"
                  data-i18n-placeholder="module.search_placeholder"
                  placeholder="Cari data..."
                  value="<%= listControls.searchValue || '' %>">
              </div>

              <div class="form-group">
                <label class="form-label" for="module-sort" data-i18n="module.sort_by">Sort by</label>
                <select class="form-select" id="module-sort" name="sort">
                  <% (listControls.sortOptions || []).forEach(function(option) { %>
                    <option value="<%= option.value %>" <%= listControls.sortValue === option.value ? 'selected' : '' %>><%= option.label %></option>
                  <% }) %>
                </select>
              </div>

              <div class="form-group">
                <label class="form-label" for="module-direction" data-i18n="module.direction">Direction</label>
                <select class="form-select" id="module-direction" name="direction">
                  <% (listControls.directionOptions || []).forEach(function(option) { %>
                    <option value="<%= option.value %>" <%= listControls.directionValue === option.value ? 'selected' : '' %>><%= option.label %></option>
                  <% }) %>
                </select>
              </div>

              <div class="form-group">
                <label class="form-label" for="module-per-page" data-i18n="module.per_page">Per page</label>
                <select class="form-select" id="module-per-page" name="perPage">
                  <% (listControls.pageSizeOptions || []).forEach(function(option) { %>
                    <option value="<%= option.value %>" <%= String(listControls.perPageValue) === String(option.value) ? 'selected' : '' %>><%= option.label %></option>
                  <% }) %>
                </select>
              </div>

              <% (listControls.extraFields || []).forEach(function(field) { %>
                <div class="form-group">
                  <label class="form-label" for="module-extra-<%= field.name %>"><%= field.label %></label>
                  <select class="form-select" id="module-extra-<%= field.name %>" name="<%= field.name %>">
                    <% (field.options || []).forEach(function(option) { %>
                      <option value="<%= option.value %>" <%= String(field.value || '') === String(option.value) ? 'selected' : '' %>><%= option.label %></option>
                    <% }) %>
                  </select>
                </div>
              <% }) %>
            </div>

            <div class="module-filters__actions">
              <button class="btn btn-primary" type="submit" data-i18n="module.apply">Apply</button>
              <a class="btn btn-secondary" href="<%= listControls.action %>" data-i18n="module.reset">Reset</a>
            </div>
          </form>
        <% } %>

        <div class="table-wrap">
          <table class="table">
            <thead>
              <tr>
                <% tableHeaders.forEach(function(header) { %>
                  <th><%= header %></th>
                <% }) %>
                <% if (hasActions) { %>
                  <th data-i18n="module.actions">Aksi</th>
                <% } %>
              </tr>
            </thead>
            <tbody>
              <% if (tableRows && tableRows.length) { %>
                <% tableRows.forEach(function(row) { %>
                  <tr>
                    <% row.cells.forEach(function(cell) { %>
                      <td>
                        <% if (cell && typeof cell === 'object' && cell.type === 'image') { %>
                          <div class="table-media">
                            <button
                              class="table-media__button"
                              type="button"
                              data-table-image-open
                              data-table-image-src="<%= cell.src %>"
                              data-table-image-alt="<%= cell.alt || cell.label || 'Image' %>">
                              <img
                                class="table-media__image"
                                src="<%= cell.src %>"
                                alt="<%= cell.alt || cell.label || 'Image' %>">
                            </button>
                          </div>
                        <% } else if (cell && typeof cell === 'object' && cell.type === 'image-placeholder') { %>
                          <div class="table-media">
                            <div class="table-media__placeholder" aria-label="<%= cell.label || 'No image' %>">
                              <span><%= String(cell.label || 'SS').trim().charAt(0).toUpperCase() || 'S' %></span>
                            </div>
                          </div>
                        <% } else if (cell && typeof cell === 'object' && cell.type === 'link') { %>
                          <a href="<%= cell.href %>"><%= cell.label %></a>
                        <% } else { %>
                          <%= cell %>
                        <% } %>
                      </td>
                    <% }) %>
                    <% if (hasActions) { %>
                      <td>
                        <div class="module-table-actions">
                          <% (row.actions || []).forEach(function(action) { %>
                            <% if (action.type === 'form') { %>
                              <form class="inline-form" action="<%= action.action %>" method="post">
                                <% if (typeof csrfToken !== 'undefined' && csrfToken) { %>
                                  <input type="hidden" name="csrfToken" value="<%= csrfToken %>">
                                <% } %>
                                <button
                                  class="btn <%= action.variant === 'danger' ? 'btn-danger' : 'btn-secondary' %> btn-sm"
                                  type="submit"
                                  <%= action.confirmMessage ? `onclick='return confirm(${JSON.stringify(action.confirmMessage)})'` : '' %>>
                                  <%= action.label %>
                                </button>
                              </form>
                            <% } else if (action.type === 'modal') { %>
                              <button
                                class="btn <%= action.variant === 'danger' ? 'btn-danger' : 'btn-secondary' %> btn-sm"
                                type="button"
                                data-edit-modal-open
                                data-edit-modal-payload="<%- encodeURIComponent(JSON.stringify(action.payload || {})) %>">
                                <%= action.label %>
                              </button>
                            <% } else { %>
                              <a class="btn <%= action.variant === 'danger' ? 'btn-danger' : 'btn-secondary' %> btn-sm" href="<%= action.href %>">
                                <%= action.label %>
                              </a>
                            <% } %>
                          <% }) %>
                        </div>
                      </td>
                    <% } %>
                  </tr>
                <% }) %>
              <% } else { %>
                <tr>
                  <td colspan="<%= tableHeaders.length + (hasActions ? 1 : 0) %>" class="text-center text-muted">
                    <%= emptyMessage %>
                  </td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>

        <% if (typeof pagination !== 'undefined' && pagination && pagination.totalPages > 1) { %>
          <div class="pagination">
            <p
              class="pagination__info"
              data-i18n-template="pagination.info"
              data-i18n-start="<%= pagination.startIndex %>"
              data-i18n-end="<%= pagination.endIndex %>"
              data-i18n-total="<%= pagination.totalItems %>">
              Menampilkan <%= pagination.startIndex %>-<%= pagination.endIndex %> dari <%= pagination.totalItems %> data
            </p>

            <div class="pagination__actions">
              <% if (pagination.prevUrl) { %>
                <a class="btn btn-secondary btn-sm" href="<%= pagination.prevUrl %>" data-i18n="pagination.prev">Prev</a>
              <% } %>

              <div class="pagination__pages">
                <% pagination.pages.forEach(function(page) { %>
                  <a
                    class="pagination__page <%= page.isCurrent ? 'pagination__page--active' : '' %>"
                    href="<%= page.url %>"
                    aria-current="<%= page.isCurrent ? 'page' : 'false' %>">
                    <%= page.page %>
                  </a>
                <% }) %>
              </div>

              <% if (pagination.nextUrl) { %>
                <a class="btn btn-secondary btn-sm" href="<%= pagination.nextUrl %>" data-i18n="pagination.next">Next</a>
              <% } %>
            </div>
          </div>
        <% } %>
      </section>

      <% if (typeof editModal !== 'undefined' && editModal) { %>
        <div class="modal is-hidden" data-edit-modal aria-hidden="true">
          <div class="modal__panel" role="dialog" aria-modal="true" aria-labelledby="edit-modal-title" aria-describedby="edit-modal-description">
            <div class="modal__header">
              <div>
                <h3 class="modal__title" id="edit-modal-title"><%= editModal.title %></h3>
                <p class="modal__description" id="edit-modal-description"><%= editModal.description %></p>
              </div>
              <button class="modal__close" type="button" data-modal-close aria-label="Tutup modal">✕</button>
            </div>

            <div class="modal__body">
              <% const modalHasFileField = (editModal.fields || []).some(function(field) { return field.type === 'file'; }); %>
              <form class="form form-page" method="post" data-edit-modal-form <% if (modalHasFileField) { %>enctype="multipart/form-data"<% } %>>
                <% if (typeof csrfToken !== 'undefined' && csrfToken) { %>
                  <input type="hidden" name="csrfToken" value="<%= csrfToken %>">
                <% } %>
                <% const modalImageField = (editModal.fields || []).find(function(field) { return field.name === 'product_image'; }); %>
                <% if (modalImageField) { %>
                  <section class="product-preview-card product-preview-card--compact" data-edit-image-preview-card>
                    <button class="product-preview-card__media" type="button" data-edit-image-preview-open aria-label="Lihat gambar lebih besar">
                      <img
                        class="product-preview-card__image is-hidden"
                        src=""
                        alt="Preview product image"
                        data-edit-image-preview-image>
                      <div class="product-preview-card__placeholder" data-edit-image-preview-placeholder>
                        <span>SS</span>
                      </div>
                    </button>
                    <div class="product-preview-card__copy">
                      <p class="product-preview-card__eyebrow">Preview</p>
                      <h3>Product Image</h3>
                      <p data-edit-image-preview-text>Belum ada gambar produk.</p>
                      <span class="product-preview-card__hint">Klik preview untuk memperbesar.</span>
                    </div>
                  </section>
                <% } %>
                <div class="form-grid">
                  <% editModal.fields.forEach(function(field) { %>
                    <div class="form-group <%= field.type === 'textarea' ? 'form-group--full' : '' %>">
                      <label class="form-label" for="modal-<%= field.name %>">
                        <%= field.label %>
                        <% if (field.required) { %><span aria-hidden="true">*</span><% } %>
                      </label>

                      <% if (field.type === 'textarea') { %>
                        <textarea
                          class="form-textarea"
                          id="modal-<%= field.name %>"
                          name="<%= field.name %>"
                          data-edit-modal-field="<%= field.name %>"
                          <%= field.required ? 'required' : '' %>></textarea>
                      <% } else if (field.type === 'select') { %>
                        <select
                          class="form-select"
                          id="modal-<%= field.name %>"
                          name="<%= field.name %>"
                          data-edit-modal-field="<%= field.name %>"
                          <%= field.required ? 'required' : '' %>>
                          <% (field.options || []).forEach(function(option) { %>
                            <option value="<%= option.value %>"><%= option.label %></option>
                          <% }) %>
                        </select>
                      <% } else if (field.type === 'file') { %>
                        <input
                          class="form-input"
                          id="modal-<%= field.name %>"
                          name="<%= field.name %>"
                          type="file"
                          <% if (field.accept) { %>accept="<%= field.accept %>"<% } %>>
                        <% if (field.name === 'product_image') { %>
                          <p class="form-help">Format gambar umum didukung. Ukuran file maksimal 2 MB.</p>
                        <% } %>
                      <% } else { %>
                        <input
                          class="form-input"
                          id="modal-<%= field.name %>"
                          name="<%= field.name %>"
                          type="<%= field.type %>"
                          data-edit-modal-field="<%= field.name %>"
                          <%= field.required ? 'required' : '' %>>
                      <% } %>
                      <% if (field.error) { %>
                        <p class="field-error"><%= field.error %></p>
                      <% } else if (field.helpText) { %>
                        <p class="form-help"><%= field.helpText %></p>
                      <% } %>
                    </div>
                  <% }) %>
                </div>

                <div class="modal__actions">
                  <button class="btn btn-secondary" type="button" data-modal-close>Batal</button>
                  <button class="btn btn-primary" type="submit" data-edit-modal-submit><%= editModal.submitLabel %></button>
                </div>
              </form>
            </div>
          </div>
        </div>
      <% } %>
    </main>
  </div>
</div>

<% if (typeof autoOpenEditModalPayload !== 'undefined' && autoOpenEditModalPayload) { %>
  <script id="module-auto-edit-modal-payload" type="application/json"><%- JSON.stringify(autoOpenEditModalPayload).replace(/</g, '\\u003c') %></script>
<% } %>

<div class="image-preview-modal is-hidden" data-table-image-modal aria-hidden="true">
  <div class="image-preview-modal__panel" role="dialog" aria-modal="true" aria-label="Product image preview">
    <button class="image-preview-modal__close" type="button" data-table-image-close aria-label="Tutup preview">✕</button>
    <img class="image-preview-modal__image" src="" alt="Preview gambar produk" data-table-image-modal-image>
  </div>
</div>

<%- include('../partials/footer') %>
